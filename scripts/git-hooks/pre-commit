#!/usr/bin/env bash
# ---------------------------------------------------------------------------
# pre-commit — the fast checks (a handful of seconds): exactly what the CI
# "lint" and "tests" jobs run, so a red CI on push is never a surprise.
#
# Enable once per clone:  bash scripts/setup_hooks.sh
# Bypass for an emergency commit:  git commit --no-verify
# ---------------------------------------------------------------------------
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

fail() { echo "pre-commit: $1 failed — fix it (or use --no-verify to bypass)" >&2; exit 1; }

RUFF="$(command -v ruff 2>/dev/null || echo "${HOME}/.local/bin/ruff")"
if [[ -x "$RUFF" ]]; then
  "$RUFF" check gimpsam tests || fail "ruff"
else
  echo "pre-commit: ruff not installed — skipping lint (pipx install ruff)" >&2
fi

python3 -m compileall -q gimpsam || fail "compileall"
python3 -m unittest discover -s tests -q || fail "unit tests"
